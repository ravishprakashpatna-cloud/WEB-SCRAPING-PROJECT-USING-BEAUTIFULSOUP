
# WEB SCRAPING FROM REAL WEBSITE (JOB RELATED WEBSITE)
from bs4 import BeautifulSoup
import time
import requests

print("Put some skills that you are not familiar with")
unfamiliar_skills = input("> ")
print(f"Filtering out {unfamiliar_skills}")

def find_jobs():

    html_text = requests.get(
        "https://www.timesjobs.com/job-search?keywords=python&location=&experience="
    ).text

    soup = BeautifulSoup(html_text, "lxml")

    jobs = soup.find_all("li", class_="clearfix job-bx wht-shd-bx")

    for job in jobs:

        published_date = job.find(
            "span", class_="sim-posted"
        ).span.text

        if "few" in published_date:

            company_name = job.find(
                "h3",
                class_="joblist-comp-name"
            ).text.replace(" ", "")

            skills = job.find(
                "span",
                class_="srp-skills"
            ).text.replace(" ", "")

            more_info = job.header.h2.a["href"]

            if unfamiliar_skills.lower() not in skills.lower():

                print(f"Company Name : {company_name.strip()}")
                print(f"Required Skills : {skills.strip()}")
                print(f"Published : {published_date.strip()}")
                print(f"More Info : {more_info}")

                print("")


if __name__ == "__main__":

    while True:

        find_jobs()

        print("Waiting 10 minutes...")

        time.sleep(600)
